# Port serwera HTTP
PORT=3000

# Sekret do podpisywania tokenow JWT (w produkcji ustaw dlugi, losowy ciag)
JWT_SECRET=zmien-ten-sekret-na-bardzo-dlugi-losowy-ciag
JWT_EXPIRES_IN=2h

# Sciezka do pliku bazy SQLite (":memory:" dla bazy w pamieci - uzywane w testach)
DB_FILE=./data/auction.db

# Poziom logowania: error | warn | info | http | debug
LOG_LEVEL=info

# Adres frontendu dozwolony w CORS
CORS_ORIGIN=http://localhost:5173
